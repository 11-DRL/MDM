# Azure Function — zmienne środowiskowe
# W Azure Portal: Function App → Configuration → Application Settings

# Fabric SQL Endpoint
FABRIC_SQL_SERVER=<workspace-id>.<region>.pbidedicated.windows.net
FABRIC_DATABASE=lh_mdm

# Managed Identity musi mieć rolę "Contributor" w Fabric Workspace
# Nie potrzebujesz żadnych haseł — MSI loguje się automatycznie
