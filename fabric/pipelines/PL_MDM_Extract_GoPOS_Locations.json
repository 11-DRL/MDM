{
  "name": "PL_MDM_Extract_GoPOS_Locations",
  "properties": {
    "description": "Pobiera lokalizacje z GoPOS API i appenduje do bronze.gopos_locations (Delta).",
    "activities": [
      {
        "name": "ACT_WEB_FetchGoPOSLocations",
        "type": "WebActivity",
        "dependsOn": [],
        "typeProperties": {
          "method": "GET",
          "url": {
            "value": "@concat(pipeline().globalParameters.GoPOSApiBaseUrl, '/v1/locations?page=1&per_page=200')",
            "type": "Expression"
          },
          "headers": {
            "Authorization": {
              "value": "@concat('Bearer ', pipeline().globalParameters.GoPOSApiToken)",
              "type": "Expression"
            },
            "Content-Type": "application/json"
          }
        }
      },
      {
        "name": "ACT_NTB_AppendBronze",
        "type": "SynapseNotebook",
        "dependsOn": [
          { "activity": "ACT_WEB_FetchGoPOSLocations", "dependencyConditions": ["Succeeded"] }
        ],
        "typeProperties": {
          "notebook": { "referenceName": "nb_bronze_append_gopos", "type": "NotebookReference" },
          "parameters": {
            "run_id":       { "value": "@pipeline().parameters.__paramRunId", "type": "string" },
            "tenant_name":  { "value": "@pipeline().parameters.__paramTenantName", "type": "string" },
            "payload_json": {
              "value": "@string(activity('ACT_WEB_FetchGoPOSLocations').output)",
              "type": "string"
            }
          }
        }
      },
      {
        "name": "ACT_SPRC_LogExtract",
        "type": "Script",
        "dependsOn": [
          { "activity": "ACT_NTB_AppendBronze", "dependencyConditions": ["Succeeded"] }
        ],
        "typeProperties": {
          "scripts": [{
            "type": "NonQuery",
            "text": {
              "value": "@concat('INSERT INTO mdm_config.execution_log (run_id, entity_id, process_name, status, started_at, completed_at) VALUES (''', pipeline().parameters.__paramRunId, ''', ''business_location'', ''PL_MDM_Extract_GoPOS_Locations'', ''Completed'', current_timestamp(), current_timestamp())')",
              "type": "Expression"
            }
          }]
        },
        "linkedServiceName": { "referenceName": "LS_Fabric_Lakehouse", "type": "LinkedServiceReference" }
      }
    ],
    "parameters": {
      "__paramRunId":      { "type": "string" },
      "__paramTenantName": { "type": "string", "defaultValue": "losteria" }
    },
    "folder": { "name": "MDM/Extract" },
    "annotations": ["mdm", "bronze", "gopos", "extract"]
  }
}
