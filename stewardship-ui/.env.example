# Zmienne środowiskowe dla Stewardship UI
# Skopiuj do .env i uzupełnij wartości

# Tryb mock (local dev bez Azure)
VITE_MOCK_MODE=true

# Azure AD — App Registration
VITE_TENANT_ID=5d842dfd-009e-4f2f-bb85-78670fa303bb
VITE_CLIENT_ID=e902f516-fc6d-4b45-8e19-3ba2dc030cce

# Azure Function URL (write proxy)
