# Zmienne środowiskowe dla Stewardship UI
# Skopiuj do .env i uzupełnij wartości

# Fabric SQL Analytics Endpoint (read)
# Znajdziesz w: Fabric Workspace → Lakehouse → SQL Analytics Endpoint → Connection String
VITE_FABRIC_SQL_ENDPOINT=https://<workspace-id>.<region>.pbidedicated.windows.net

# Azure Function URL (write proxy do BV tables)
# Deployuj funkcję z azure-function/ po konfiguracją
VITE_WRITE_API_URL=https://<function-app-name>.azurewebsites.net

# Azure AD — App Registration
# Utwórz w: Azure Portal → App Registrations → New registration
# Redirect URI: http://localhost:3000 (dev), https://<prod-url> (prod)
VITE_TENANT_ID=<azure-tenant-id>
VITE_CLIENT_ID=<app-registration-client-id>
